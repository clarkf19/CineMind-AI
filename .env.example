# ==============================================================================
# CineMind AI - Environment Variables Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration (FastAPI)
# ------------------------------------------------------------------------------
# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins.
# - Local Dev: http://localhost:3000
# - Production: https://your-frontend-vercel-url.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# Frontend Configuration (Next.js)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE: The URL of the deployed FastAPI backend.
# - Local Dev: http://localhost:8000
# - Production: https://your-backend-render-url.onrender.com
NEXT_PUBLIC_API_BASE=http://localhost:8000
